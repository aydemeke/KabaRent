# KabaRent backend — environment template.
# Copy to a local .env (or export these in your shell / Render dashboard) and fill in real
# values. NEVER commit real secrets. application.properties reads these via ${...}.

# --- Database (PostgreSQL; Neon in production) ---
# Local dev example shown; in production use the Neon connection string.
DB_URL=jdbc:postgresql://localhost:5432/kabarent
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Auth ---
# HMAC signing key for JWTs. Use a long random value (>= 32 bytes).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# Admin account seeded on startup (admin logs in by EMAIL + password).
# Seeding is skipped if ADMIN_PASSWORD is blank.
ADMIN_EMAIL=admin@kabarent.local
ADMIN_PASSWORD=change-me
