# KabaRent frontend — environment template.
# Copy to .env.local for local development: cp .env.example .env.local
# (.env.local is git-ignored; the tracked .env.production holds the prod value.)

# Base URL for the backend API (consumed by src/api/axiosInstance.js). There is no dev
# proxy, so this must be set in every environment.
#   Local dev (run the backend on :8080): http://localhost:8080/api
#   Production (Render backend):           https://kabarent.onrender.com/api
VITE_API_URL=http://localhost:8080/api
