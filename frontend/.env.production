# Loaded automatically by `vite build` (production mode), e.g. on Vercel.
# Supplies the baseURL for the shared axios `api` instance
# (src/api/axiosInstance.js reads `import.meta.env.VITE_API_URL`).
# Without this, VITE_API_URL is undefined in the prod build, axios falls back
# to an empty baseURL, and every API call resolves against the Vercel origin
# (e.g. https://kaba-rent.vercel.app/kabas/available -> 404, no /api prefix).
VITE_API_URL=https://kabarent.onrender.com/api
